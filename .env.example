# Copy to .env.local and fill in. For local dev, run `supabase start` and use
# the URL + Publishable + Secret keys it prints.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Drive service account. Create one in GCP, share the parent batch-doc
# folder with the service account email (Viewer is enough). The private key
# is stored as a quoted string with literal \n escapes; the app decodes at
# runtime.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
