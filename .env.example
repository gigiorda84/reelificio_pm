# Copy to .env.local and fill in. For local dev, run `supabase start` and use
# the URL + Publishable + Secret keys it prints.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Drive service account. Create one in GCP, share the parent batch-doc
# folder with the service account email (Viewer is enough). The private key
# is stored as a quoted string with literal \n escapes; the app decodes at
# runtime.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Resend transactional email. Sandbox sender (`onboarding@resend.dev`) works
# without DNS setup; replace EMAIL_FROM with a verified-domain address before
# going live.
RESEND_API_KEY=
EMAIL_FROM="Reellificio PM <onboarding@resend.dev>"

# Telegram bot. Create via @BotFather, paste the token here. Each user links
# their personal chat by messaging the bot once with the linking code shown
# in /settings; the webhook (configured separately) stores the chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Cron auth. Vercel Cron sends requests with this header; reject anything else.
CRON_SECRET=
